{
  "name": "m-spec",
  "version": "0.1.0",
  "description": "Lightweight spec-driven development framework for brownfield AI agent workflows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "m-spec": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .vitest",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
