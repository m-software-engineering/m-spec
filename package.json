{
  "name": "@m-software-engineering/m-spec",
  "version": "0.1.1",
  "description": "Lightweight spec-driven development framework for brownfield AI agent workflows.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-software-engineering/m-spec.git"
  },
  "bugs": {
    "url": "https://github.com/m-software-engineering/m-spec/issues"
  },
  "homepage": "https://github.com/m-software-engineering/m-spec#readme",
  "bin": {
    "m-spec": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .vitest",
    "changeset": "changeset",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "release": "npm publish --access public --provenance",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "version-packages": "changeset version && npm install --package-lock-only --ignore-scripts"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
