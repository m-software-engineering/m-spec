          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/{{RUNTIME_ROOT}}/hooks/protect-secrets.mjs\""
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/{{RUNTIME_ROOT}}/hooks/test-integrity.mjs\""
          }
        ]
      }
    ]
  }
}
